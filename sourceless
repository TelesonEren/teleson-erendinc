<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sourceless – STR Dome Starter Package</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@700;900&family=Exo+2:wght@300;400;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --green:        #8dce3c;
    --green-light:  #b4e055;
    --green-dark:   #5fa020;
    --purple:       #7752aa;
    --purple-light: #9b72cc;
    --purple-dark:  #4a2c80;
    --bg:           #0c0d12;
    --card-bg:      rgba(18,12,32,0.75);
    --border-glow:  rgba(141,206,60,0.35);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: #dde8dd;
    font-family: 'Exo 2', sans-serif;
    overflow-x: hidden;
    min-height: 100vh;
  }

  /* ── Background atmosphere ── */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 50% at 20% 10%, rgba(119,82,170,0.18) 0%, transparent 65%),
      radial-gradient(ellipse 60% 45% at 80% 80%, rgba(141,206,60,0.10) 0%, transparent 60%),
      radial-gradient(ellipse 50% 40% at 50% 50%, rgba(74,44,128,0.12) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  .stars {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background-image:
      radial-gradient(1px 1px at 8%  12%, rgba(255,255,255,0.65) 0%, transparent 100%),
      radial-gradient(1px 1px at 22% 38%, rgba(255,255,255,0.45) 0%, transparent 100%),
      radial-gradient(1.5px 1.5px at 38% 8%, rgba(255,255,255,0.75) 0%, transparent 100%),
      radial-gradient(1px 1px at 53% 58%, rgba(255,255,255,0.35) 0%, transparent 100%),
      radial-gradient(1px 1px at 68% 28%, rgba(255,255,255,0.55) 0%, transparent 100%),
      radial-gradient(2px 2px at 83% 72%, rgba(180,160,255,0.5) 0%, transparent 100%),
      radial-gradient(1px 1px at 91% 18%, rgba(255,255,255,0.65) 0%, transparent 100%),
      radial-gradient(1px 1px at 14% 68%, rgba(255,255,255,0.40) 0%, transparent 100%),
      radial-gradient(1px 1px at 58% 83%, rgba(255,255,255,0.55) 0%, transparent 100%),
      radial-gradient(1.5px 1.5px at 76% 52%, rgba(200,180,255,0.7) 0%, transparent 100%),
      radial-gradient(1px 1px at 31% 88%, rgba(255,255,255,0.45) 0%, transparent 100%),
      radial-gradient(1px 1px at 45% 48%, rgba(255,255,255,0.28) 0%, transparent 100%),
      radial-gradient(1px 1px at 5%  55%, rgba(141,206,60,0.5)   0%, transparent 100%),
      radial-gradient(1px 1px at 96% 44%, rgba(141,206,60,0.4)   0%, transparent 100%);
  }

  .wrapper { position: relative; z-index: 1; }

  /* ── NAV ── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 32px;
    background: rgba(12,13,18,0.88);
    backdrop-filter: blur(18px);
    border-bottom: 1px solid rgba(119,82,170,0.25);
  }

  .nav-logo {
    font-family: 'Orbitron', monospace;
    font-size: 1rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    background: linear-gradient(90deg, var(--green), var(--purple-light));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .nav-cta {
    cursor: pointer;
    font-family: 'Orbitron', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 9px 22px;
    background: transparent;
    border: 1px solid var(--green);
    color: var(--green);
    border-radius: 3px;
    text-decoration: none;
    transition: background 0.2s, box-shadow 0.2s;
  }
  .nav-cta:hover {
    background: rgba(141,206,60,0.12);
    box-shadow: 0 0 18px rgba(141,206,60,0.35);
  }

  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 60px 20px 40px;
    text-align: center;
    position: relative;
  }

  /* Orbit rings */
  .orbit-ring {
    position: absolute;
    border-radius: 50%;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
    animation: spin 35s linear infinite;
  }
  .orbit-ring:nth-child(1) {
    width: 320px; height: 320px;
    border: 1px solid rgba(141,206,60,0.10);
  }
  .orbit-ring:nth-child(2) {
    width: 520px; height: 520px;
    border: 1px solid rgba(119,82,170,0.10);
    animation-duration: 55s;
    animation-direction: reverse;
  }

  .hero-badge {
    display: inline-block;
    background: linear-gradient(135deg, rgba(119,82,170,0.18), rgba(141,206,60,0.08));
    border: 1px solid rgba(119,82,170,0.5);
    color: var(--purple-light);
    font-family: 'Orbitron', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    padding: 6px 18px;
    border-radius: 2px;
    margin-bottom: 24px;
    animation: fadeDown 0.8s ease both;
  }

  .hero-logo {
    font-family: 'Orbitron', monospace;
    font-size: clamp(2.8rem, 8vw, 6rem);
    font-weight: 900;
    line-height: 1;
    letter-spacing: 0.04em;
    background: linear-gradient(135deg, var(--green-light) 0%, var(--green) 35%, var(--purple-light) 70%, var(--purple) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 8px;
    animation: fadeDown 0.9s ease 0.1s both;
    filter: drop-shadow(0 0 28px rgba(119,82,170,0.4));
  }

  .hero-sub {
    font-family: 'Orbitron', monospace;
    font-size: clamp(0.9rem, 2.5vw, 1.3rem);
    font-weight: 700;
    color: var(--purple-light);
    letter-spacing: 0.2em;
    margin-bottom: 16px;
    animation: fadeDown 0.9s ease 0.2s both;
  }

  .hero-desc {
    font-size: clamp(0.95rem, 2vw, 1.15rem);
    color: rgba(200,210,230,0.65);
    max-width: 560px;
    line-height: 1.7;
    margin: 0 auto 40px;
    animation: fadeDown 0.9s ease 0.3s both;
  }

  /* Price */
  .price-tag {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    background: linear-gradient(135deg, rgba(119,82,170,0.18), rgba(141,206,60,0.08));
    border: 2px solid var(--purple);
    border-radius: 8px;
    padding: 20px 40px;
    margin-bottom: 40px;
    animation: fadeUp 1s ease 0.4s both;
    box-shadow: 0 0 50px rgba(119,82,170,0.25), inset 0 0 30px rgba(119,82,170,0.06);
  }

  .price-label {
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    color: var(--purple-light);
    text-transform: uppercase;
    margin-bottom: 4px;
    font-family: 'Orbitron', monospace;
  }

  .price-num {
    font-family: 'Orbitron', monospace;
    font-size: clamp(3rem, 10vw, 5.5rem);
    font-weight: 900;
    line-height: 1;
    background: linear-gradient(135deg, #fff 0%, var(--green-light) 50%, var(--purple-light) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    filter: drop-shadow(0 0 20px rgba(141,206,60,0.4));
  }

  .price-plan {
    font-size: 0.85rem;
    color: var(--green);
    font-family: 'Orbitron', monospace;
    letter-spacing: 0.15em;
    margin-top: 6px;
  }

  /* Scroll hint */
  .scroll-hint {
    position: absolute;
    bottom: 30px; left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    opacity: 0.45;
    animation: bounce 2s infinite;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    color: var(--green);
    text-transform: uppercase;
    text-decoration: none;
  }
  .scroll-hint::after {
    content: '';
    width: 1px; height: 40px;
    background: linear-gradient(to bottom, var(--green), transparent);
  }

  /* ── DIVIDER ── */
  .divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--purple), var(--green-dark), transparent);
    opacity: 0.25;
    margin: 0 40px;
  }

  /* ── VIDEO SECTION ── */
  .video-section {
    padding: 80px 20px 60px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .section-label {
    font-family: 'Orbitron', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.4em;
    color: var(--green);
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .section-title {
    font-family: 'Orbitron', monospace;
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    font-weight: 900;
    color: #fff;
    text-align: center;
    margin-bottom: 40px;
  }
  .section-title em {
    font-style: normal;
    background: linear-gradient(90deg, var(--green), var(--purple-light));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .video-frame {
    width: 100%; max-width: 820px;
    position: relative;
    border-radius: 10px;
    overflow: hidden;
    border: 2px solid rgba(119,82,170,0.4);
    box-shadow:
      0 0 60px rgba(119,82,170,0.2),
      0 0 30px rgba(141,206,60,0.08),
      0 0 120px rgba(0,0,0,0.8);
  }
  .video-frame::before {
    content: '';
    display: block;
    padding-top: 56.25%;
  }
  .video-frame iframe {
    position: absolute;
    inset: 0;
    width: 100%; height: 100%;
    border: none;
  }

  /* ── CTA BUTTON ── */
  .cta-btn {
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    margin-top: 36px;
    padding: 18px 48px;
    font-family: 'Orbitron', monospace;
    font-size: clamp(0.85rem, 2.5vw, 1.05rem);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-decoration: none;
    color: #fff;
    background: linear-gradient(135deg, var(--green-dark) 0%, var(--green) 40%, var(--purple) 80%, var(--purple-dark) 100%);
    border-radius: 4px;
    transition: transform 0.2s, box-shadow 0.2s, filter 0.2s;
    box-shadow: 0 0 30px rgba(119,82,170,0.45), 0 4px 20px rgba(0,0,0,0.5);
    position: relative;
    overflow: hidden;
  }
  .cta-btn::before {
    content: '';
    position: absolute;
    top: -50%; left: -60%;
    width: 40%; height: 200%;
    background: rgba(255,255,255,0.2);
    transform: skewX(-20deg);
    transition: left 0.5s ease;
  }
  .cta-btn:hover::before { left: 130%; }
  .cta-btn:hover {
    transform: translateY(-3px) scale(1.03);
    box-shadow: 0 0 50px rgba(119,82,170,0.65), 0 8px 30px rgba(0,0,0,0.5);
    filter: brightness(1.12);
  }
  .cta-arrow { font-size: 1.2em; transition: transform 0.2s; }
  .cta-btn:hover .cta-arrow { transform: translateX(5px); }

  /* ── BENEFITS ── */
  .benefits {
    padding: 80px 20px;
    max-width: 900px;
    margin: 0 auto;
  }

  .benefits-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    margin-top: 40px;
  }
  @media (min-width: 640px) {
    .benefits-grid { grid-template-columns: 1fr 1fr; }
  }

  .benefit-card {
    background: var(--card-bg);
    border: 1px solid var(--border-glow);
    border-radius: 8px;
    padding: 24px 28px;
    display: flex;
    align-items: flex-start;
    gap: 18px;
    backdrop-filter: blur(12px);
    transition: border-color 0.3s, box-shadow 0.3s, transform 0.3s;
    position: relative;
    overflow: hidden;
  }
  .benefit-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(141,206,60,0.04), transparent);
    pointer-events: none;
  }
  .benefit-card:hover {
    border-color: var(--green);
    box-shadow: 0 0 22px rgba(141,206,60,0.18);
    transform: translateY(-2px);
  }

  .benefit-card.highlight {
    border-color: rgba(119,82,170,0.5);
    background: rgba(25,10,45,0.75);
  }
  .benefit-card.highlight::before {
    background: linear-gradient(135deg, rgba(119,82,170,0.07), transparent);
  }
  .benefit-card.highlight:hover {
    border-color: var(--purple-light);
    box-shadow: 0 0 22px rgba(119,82,170,0.3);
  }

  .check-icon {
    flex-shrink: 0;
    width: 36px; height: 36px;
    border-radius: 50%;
    background: linear-gradient(135deg, rgba(141,206,60,0.18), rgba(141,206,60,0.04));
    border: 2px solid var(--green);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--green);
    font-size: 1.1rem;
    box-shadow: 0 0 12px rgba(141,206,60,0.3);
  }
  .benefit-card.highlight .check-icon {
    border-color: var(--purple-light);
    color: var(--purple-light);
    background: linear-gradient(135deg, rgba(119,82,170,0.2), rgba(119,82,170,0.04));
    box-shadow: 0 0 12px rgba(119,82,170,0.35);
  }

  .benefit-text strong {
    display: block;
    font-size: 1.05rem;
    color: #fff;
    font-weight: 600;
    margin-bottom: 4px;
  }
  .benefit-text strong em {
    font-style: normal;
    color: var(--green);
  }
  .benefit-card.highlight .benefit-text strong em {
    color: var(--purple-light);
  }
  .benefit-text p {
    font-size: 0.85rem;
    color: rgba(190,200,220,0.6);
    line-height: 1.5;
  }

  /* ── FINAL BANNER ── */
  .lifetime-banner {
    max-width: 860px;
    margin: 0 auto 80px;
    padding: 0 20px;
  }

  .lifetime-banner-inner {
    background: linear-gradient(135deg, rgba(119,82,170,0.18) 0%, rgba(141,206,60,0.08) 100%);
    border: 2px solid var(--purple);
    border-radius: 10px;
    padding: 48px 40px;
    text-align: center;
    position: relative;
    overflow: hidden;
    box-shadow: 0 0 70px rgba(119,82,170,0.2), 0 0 30px rgba(141,206,60,0.08);
  }
  .lifetime-banner-inner::before {
    content: '';
    position: absolute;
    top: -50%; left: -20%;
    width: 140%; height: 200%;
    background: radial-gradient(ellipse at center, rgba(119,82,170,0.08), transparent 70%);
    pointer-events: none;
  }

  .lifetime-title {
    font-family: 'Orbitron', monospace;
    font-size: clamp(1.6rem, 5vw, 3rem);
    font-weight: 900;
    background: linear-gradient(135deg, var(--green-light), var(--purple-light));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    filter: drop-shadow(0 0 20px rgba(119,82,170,0.4));
    margin-bottom: 14px;
    position: relative;
  }

  .lifetime-desc {
    font-size: clamp(0.9rem, 2vw, 1.05rem);
    color: rgba(210,210,240,0.7);
    max-width: 560px;
    margin: 0 auto 30px;
    line-height: 1.7;
    position: relative;
  }

  /* ── FOOTER ── */
  footer {
    border-top: 1px solid rgba(119,82,170,0.2);
    padding: 40px 20px;
    text-align: center;
    color: rgba(150,140,190,0.4);
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    font-family: 'Orbitron', monospace;
  }
  footer a { color: var(--green-dark); text-decoration: none; }
  footer strong { color: rgba(190,180,220,0.55); }

  /* ── PULSING ── */
  @keyframes pulse-glow {
    0%, 100% { box-shadow: 0 0 30px rgba(119,82,170,0.4), 0 0 60px rgba(119,82,170,0.15); }
    50%       { box-shadow: 0 0 55px rgba(141,206,60,0.5),  0 0 90px rgba(119,82,170,0.2); }
  }
  .pulsing { animation: pulse-glow 3s ease-in-out infinite; }

  /* ── ANIMATIONS ── */
  @keyframes fadeDown {
    from { opacity: 0; transform: translateY(-20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50%       { transform: translateX(-50%) translateY(10px); }
  }
  @keyframes spin {
    from { transform: translate(-50%, -50%) rotate(0deg); }
    to   { transform: translate(-50%, -50%) rotate(360deg); }
  }

  /* ── SCROLL REVEAL ── */
  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>
</head>
